# CryptoPanic API Key (optional)
CRYPTOPANIC_API_KEY=your_cryptopanic_api_key_here

# Reddit User Agent (required for Reddit crawler)
REDDIT_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) ThesisBot/1.0

# Google Cloud Platform Credentials (required for GDELT BigQuery crawler)
# Set to the path of your GCP service account JSON key file
# Download from: https://console.cloud.google.com/iam-admin/serviceaccounts
# Example: /home/user/.config/gcp/service-account-key.json
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-service-account-key.json
