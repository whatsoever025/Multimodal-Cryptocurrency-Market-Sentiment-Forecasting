# Cryptocurrency Market Sentiment Forecasting - Environment Configuration
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env to version control

# ==============================================================================
# REDDIT CREDENTIALS
# ==============================================================================
# Reddit public .json endpoint only requires a User-Agent (no API key needed)
# User-Agent is a custom string that identifies your crawler to Reddit
# Format: {platform}:{application}:{version} (by u/{username})
# Example: linux:crypto-crawler:1.0 (by u/your_username)
REDDIT_USER_AGENT=your_custom_user_agent_here

# ==============================================================================
# STOCKTWITS API CREDENTIALS
# ==============================================================================
# Get your API key from: https://api.stocktwits.com/
# Register and create an application to obtain your API key
STOCKTWITS_API_KEY=your_stocktwits_api_key_here

# ==============================================================================
# GOOGLE CLOUD / BIGQUERY CREDENTIALS
# ==============================================================================
# Path to your Google Cloud service account JSON file
# Used for GDELT BigQuery access
# Generate at: https://console.cloud.google.com/iam-admin/serviceaccounts
# The file should contain your private key and service account email
GOOGLE_APPLICATION_CREDENTIALS=./google_credentials.json

# ==============================================================================
# COINALYZE API CREDENTIALS
# ==============================================================================
# Get your API key from: https://coinalyze.net/api/
# Required for Open Interest, Liquidations, Long/Short Ratio data
COINALYZE_API_KEY=your_coinalyze_api_key_here
